CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# Optional: default recipient User ID (starts with "U").
# When set, single-target messaging tools (push_*, show_loading_indicator)
# may omit "to"/"chatId" and will send to this user by default.
# An explicit "to" always overrides it. Leave unset to require "to" every time.
# DEFAULT_UID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
